# PatentLens Studio — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# ── Required ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Additional Gemini keys (rotate on rate-limit) ─────────────────
# GEMINI_API_KEY1=another_gemini_api_key
# GEMINI_API_KEY2=yet_another_gemini_api_key

# ── Optional: CAPTCHA Solver (2Captcha) ─────────────────────────────────────
# TWO_CAPTCHA_API_KEY=your_2captcha_api_key_here

# ── India Patent Search ──────────────────────────────────────────────────────
# Set to "true" for headless (production), "false" to see browser (debugging)
INDIA_PATENT_HEADLESS=true

# ── Server (set automatically on Render, override locally if needed) ─────────
# HOST=0.0.0.0
# PORT=8000
# ENV=production

# ── Database (Render will inject DATABASE_URL automatically when using the Postgres add-on) ──────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/database
# DB_PATH=/tmp/patent_lens.db
