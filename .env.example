# PatentLens Studio — Environment Variables
# Copy this file to .env and fill in your key.
# NEVER commit your .env file to version control.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: set to 1 to open a visible browser for Indian Patent Search CAPTCHA.
INDIA_PATENTS_HEADFUL=0

# Optional Fallback Gemini API keys (useful to bypass free-tier rate limits)
# GEMINI_API_KEY1=another_gemini_api_key
# GEMINI_API_KEY2=yet_another_gemini_api_key

# Optional Paid CAPTCHA Solver API keys (supported: 2Captcha)
# TWO_CAPTCHA_API_KEY=your_2captcha_api_key_here
